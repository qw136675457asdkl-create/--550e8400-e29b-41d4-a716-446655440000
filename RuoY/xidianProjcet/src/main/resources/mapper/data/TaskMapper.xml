<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.Xidian.mapper.TaskMapper">
    <resultMap id="taskResultMap" type="com.ruoyi.Xidian.domain.Task">
        <id column="id" property="id" />
        <result column="task_code" property="taskCode" />
        <result column="task_name" property="taskName" />
        <result column="project_id" property="projectId" />
        <result column="project_name" property="projectName" />
        <result column="experiment_id" property="experimentId" />
        <result column="experiment_name" property="experimentName" />
        <result column="carrier_type" property="carrierType" />
        <result column="motion_model" property="motionModel" />
        <result column="data_category_summary" property="dataCategorySummary" />
        <result column="target_type" property="targetType" />
        <result column="status" property="status" />
        <result column="path" property="path" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="create_by" property="createBy" />
        <result column="create_user_id" property="createUserId" />

        <association property="startCoordinate" javaType="com.ruoyi.Xidian.domain.Coordinate">
            <result property="lon" column="start_longitude" />
            <result property="lat" column="start_latitude" />
            <result property="alt" column="start_altitude" />
        </association>

        <association property="endCoordinate" javaType="com.ruoyi.Xidian.domain.Coordinate">
            <result property="lon" column="end_longitude" />
            <result property="lat" column="end_latitude" />
            <result property="alt" column="end_altitude" />
        </association>
    </resultMap>

    <sql id="taskSelectColumns">
        select t.id,
               t.task_code,
               t.task_name,
               t.project_id,
               p.project_name,
               t.experiment_id,
               e.experiment_name,
               t.motion_model,
               t.start_longitude,
               t.start_latitude,
               t.start_altitude,
               t.end_longitude,
               t.end_latitude,
               t.end_altitude,
               t.data_category_summary,
               t.target_type,
               t.status,
               t.path,
               t.create_by,
               t.create_time,
               t.update_time
        from SYSTEM_COLLABORATION_TEST.TASK t
                 left join SYSTEM_COLLABORATION_TEST.D_PROJECT_INFO p on t.project_id = p.project_id
                 left join SYSTEM_COLLABORATION_TEST.D_EXPERIMENT_INFO e on t.experiment_id = e.experiment_id
    </sql>

    <insert id="insert" parameterType="com.ruoyi.Xidian.domain.Task" useGeneratedKeys="true" keyProperty="id" keyColumn="ID">
        insert into SYSTEM_COLLABORATION_TEST.TASK (
            task_code,
            task_name,
            project_id,
            experiment_id,
            motion_model,
            start_longitude,
            start_latitude,
            start_altitude,
            end_longitude,
            end_latitude,
            end_altitude,
            data_category_summary,
            target_type,
            status,
            path,
            create_by,
            create_time,
            update_time
        ) values (
            #{taskCode},
            #{taskName},
            #{projectId},
            #{experimentId},
            #{motionModel},
            #{startCoordinate.lon},
            #{startCoordinate.lat},
            #{startCoordinate.alt},
            #{endCoordinate.lon},
            #{endCoordinate.lat},
            #{endCoordinate.alt},
            #{dataCategorySummary},
            #{targetType},
            #{status},
            #{path},
            #{createBy},
            #{createTime},
            #{updateTime}
        )
    </insert>

    <update id="update" parameterType="com.ruoyi.Xidian.domain.Task">
        update SYSTEM_COLLABORATION_TEST.TASK
        set status = #{status},
            path = #{path},
            update_time = #{updateTime}
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        delete from SYSTEM_COLLABORATION_TEST.TASK where id = #{id}
    </delete>

    <select id="selectList" resultMap="taskResultMap">
        <include refid="taskSelectColumns" />
        order by t.create_time desc
    </select>

    <select id="selectById" resultMap="taskResultMap">
        <include refid="taskSelectColumns" />
        where t.id = #{id}
    </select>

    <select id="selectTaskList" parameterType="com.ruoyi.Xidian.domain.Task" resultMap="taskResultMap">
        <include refid="taskSelectColumns" />
        <where>
            <if test="projectId != null">
                and t.project_id = #{projectId}
            </if>
            <if test="experimentId != null and experimentId != ''">
                and t.experiment_id = #{experimentId}
            </if>
            <if test="createBy != null and createBy != ''">
                and t.create_by like concat('%', #{createBy}, '%')
            </if>
            <if test="taskName != null and taskName != ''">
                and t.task_name like concat('%', #{taskName}, '%')
            </if>
        </where>
        order by t.create_time desc
    </select>
</mapper>
